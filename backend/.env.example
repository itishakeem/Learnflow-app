# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key
SESSION_SECRET=your-session-secret

# ── OAuth — Google ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-render-app.onrender.com/auth/google/callback

# ── OAuth — GitHub ────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://your-render-app.onrender.com/auth/github/callback

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend.vercel.app

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
STREAM_TIMEOUT=20

# ── Internal service URLs (self-referencing on Render) ────────────────────────
# Since all routes are on the same app, progress service is on the same host
PROGRESS_URL=https://your-render-app.onrender.com
