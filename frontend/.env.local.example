# Backend service URLs used by the Next.js API proxy (/api/svc/*)
# For local dev: port-forward each service and set the ports here
# For cluster: set to internal K8s DNS (defaults are already set in route.ts)

TRIAGE_URL=http://localhost:8001
CONCEPTS_URL=http://localhost:8002
EXERCISE_URL=http://localhost:8003
DEBUG_URL=http://localhost:8004
PROGRESS_URL=http://localhost:8005
